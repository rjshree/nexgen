{
  "name": "bubble",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "copy-templates": "xcopy src\\templates dist\\templates /E /I /Y",
    "build": "tsc && npm run copy-templates",
    "start": "npm run build && node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "build:exe": "npx pkg src/index.js --targets node18-win-x64 --output dist/generator.exe"

  },
  "pkg": {
    "assets": ["src/**/*"],
    "targets": ["node18-win-x64"]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "archiver": "^7.0.1",
    "fs-extra": "^11.3.4",
    "handlebars": "^4.7.9",
    "inquirer": "^13.3.2"
  },
  "devDependencies": {
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "ts-node": "^10.9.1"
  }
}
