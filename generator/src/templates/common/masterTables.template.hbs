        {
          field: '{{field}}',
          headerName: '{{headerName}}',
          {{#if width}}width: {{width}},{{/if}}
          {{#if editable}}editable: true,{{/if}}
          {{#if validation}}
          validation: {{validation}},
          {{/if}}
        },
      {{/each}}
      ],
    {{/each}}
    };
    `