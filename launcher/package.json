{
    "name": "bubble-launcher",
    "version": "1.0.0",
    "description": "Bubble Project Generator - Desktop App",
    "main": "src/cli.js",
    "bin": "src/cli.js",
    "scripts": {
        "start": "node src/cli.js",
        "build:exe": "npx pkg . --targets node18-win-x64 --output dist/Bubble.exe --public"
    },
    "pkg": {
        "assets": [],
        "targets": [
            "node18-win-x64"
        ],
        "outputPath": "dist"
    },
    "dependencies": {
        "express": "^4.22.1"
    },
    "devDependencies": {
        "pkg": "^5.8.1"
    }
}
